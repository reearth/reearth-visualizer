# ============================================================================
# Re:Earth Visualizer - Environment Variables Template
# ============================================================================
#
# USAGE:
#
# Option 1: Traditional .env file
#   1. Copy this file to .env
#   2. Replace placeholder values with your actual configuration
#   3. Run: yarn start
#
# Option 2: 1Password CLI (Recommended)
#   1. Create a 1Password item with fields matching these variables
#   2. Create .env.op (not tracked) with: op://VaultName/ItemName/field_name
#   3. Run: yarn start:op
#   See docs/1password-setup.md for detailed setup instructions
#
# ============================================================================

# ===== Authentication =====
# Auth0 configuration for user authentication

REEARTH_WEB_AUTH0_DOMAIN=<your-auth0-domain>
# Example: example.auth0.com

REEARTH_WEB_AUTH0_AUDIENCE=<your-auth0-audience>
# Example: https://api.example.com

REEARTH_WEB_AUTH0_CLIENT_ID=<your-auth0-client-id>
# Example: abc123xyz456

REEARTH_WEB_AUTH_PROVIDER=
# Optional: "auth0", "mock", or leave empty
# Use "mock" for development without Auth0

# ===== Application Configuration =====

REEARTH_WEB_CONFIG_URL=
# Optional: URL to remote reearth_config.json
# Leave empty to use default configuration
# Example: https://example.com/config.json

REEARTH_WEB_CESIUM_ION_ACCESS_TOKEN=
# Optional: Cesium Ion access token for 3D mapping features
# Leave empty to use token from config
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

REEARTH_WEB_FEATURE_COLLECTION=
# Optional: "ee" for Enterprise Edition features, or leave empty

REEARTH_WEB_ENABLE_GQL_PLAYGROUND=
# Optional: Set to "true" to enable GraphQL Playground at /graphql

# ===== API Configuration =====

REEARTH_WEB_API=http://localhost:8080/api
# Backend API URL
# Example for local: http://localhost:8080/api
# Example for remote: https://api.example.com/api

REEARTH_WEB_PLUGINS=http://localhost:8080/plugins
# Plugin endpoint URL

# ===== Plugin & Extension Configuration =====

REEARTH_WEB_UNSAFE_PLUGIN_URLS=
# Optional: JSON array of URLs for unsafe/external plugins
# Example: ["http://example.com/plugin.js", "http://example.com/plugin2.js"]

REEARTH_WEB_EXTENSION_URLS=
# Optional: JSON array of URLs for extensions
# Example: ["http://example.com/extension.js"]

REEARTH_WEB_DEV_PLUGIN_URLS=
# Optional: JSON array of URLs for development plugins
# Example: ["http://localhost:5005"]
# Useful for plugin development

# ===== External Services =====

REEARTH_WEB_PLATFORM_URL=
# Optional: External platform URL
# Example: https://platform.example.com

# ============================================================================
# NOTES:
# - All variables must be prefixed with REEARTH_WEB_
# - Environment variables are only used during development (yarn start)
# - Build and test processes don't use these variables
# ============================================================================
