# Re:Earth Visualizer Environment Variables
# Copy this file to .env for local development

# ===== Authentication Configuration =====
REEARTH_WEB_AUTH0_DOMAIN=<your-auth0-domain>
REEARTH_WEB_AUTH0_AUDIENCE=<your-auth0-audience>
REEARTH_WEB_AUTH0_CLIENT_ID=<your-auth0-client-id>

REEARTH_WEB_AUTH_PROVIDER=  # Optional, "auth0", "mock", or leave empty for default auth0

# ===== Application Configuration =====
REEARTH_WEB_CONFIG_URL= # Optional, URL to your reearth_config.json, or leave empty to use the default configuration
REEARTH_WEB_FEATURE_COLLECTION= # Optional, "ee" or left empty for default feature collection
REEARTH_WEB_ENABLE_GQL_PLAYGROUND= # Optional, set to "true" to enable GraphQL Playground

# ===== Tile Provider Configuration =====
# Options: "terravista" or "custom" (leave empty for no system provider)
# Note: Cesium Ion terrain is configured per-scene in the editor (not here)
REEARTH_WEB_TILE_PROVIDER_TYPE=
# Terravista settings (required if TILE_PROVIDER_TYPE is "terravista")
REEARTH_WEB_TERRAVISTA_ACCESS_TOKEN=                          # Your Terravista access token
REEARTH_WEB_TERRAVISTA_BASE_URL=https://tiles.eukarya.io      # All endpoints below default to this base URL
# Individual endpoint overrides (optional — each defaults to {BASE_URL}/<path> if not set)
REEARTH_WEB_TERRAVISTA_TERRAIN_URL=https://tiles.eukarya.io/cesium-mesh/ellipsoid
REEARTH_WEB_TERRAVISTA_TERRAIN_CREDIT=
REEARTH_WEB_TERRAVISTA_IMAGERY_DEFAULT_URL=https://tiles.eukarya.io/imagery/google-satellite/{z}/{x}/{y}.webp
REEARTH_WEB_TERRAVISTA_IMAGERY_DEFAULT_CREDIT=© Google
REEARTH_WEB_TERRAVISTA_IMAGERY_ROAD_URL=https://tiles.eukarya.io/imagery/google-roadmap/{z}/{x}/{y}.webp
REEARTH_WEB_TERRAVISTA_IMAGERY_ROAD_CREDIT=© Google
REEARTH_WEB_TERRAVISTA_IMAGERY_BLACK_MARBLE_URL=https://tiles.eukarya.io/imagery/blackmarble/{z}/{x}/{y}.png
REEARTH_WEB_TERRAVISTA_IMAGERY_BLACK_MARBLE_CREDIT=NASA GIBS VIIRS
REEARTH_WEB_TERRAVISTA_IMAGERY_OSM_URL=https://tiles.eukarya.io/imagery/osm/{z}/{x}/{y}.png
REEARTH_WEB_TERRAVISTA_IMAGERY_OSM_CREDIT=© OpenStreetMap contributors
REEARTH_WEB_TERRAVISTA_GOOGLE3D_URL=https://tiles.eukarya.io/google3d/root.json
REEARTH_WEB_TERRAVISTA_GOOGLE3D_CREDIT=

# ===== API Configuration =====
REEARTH_WEB_API=http://localhost:8080/api

# ===== Plugin Configuration =====
REEARTH_WEB_PLUGINS=http://localhost:8080/plugins
REEARTH_WEB_UNSAFE_PLUGIN_URLS='["http://example.com/plugin.js"]' # Optional, URLs for unsafe plugins, adjust as needed

# ===== Extensions Configuration =====
REEARTH_WEB_EXTENSION_URLS='["http://example.com/extension.js"]' # Optional, URLs for extensions, adjust as needed

# ===== Development Configuration =====
REEARTH_WEB_DEV_PLUGIN_URLS='["http://localhost:5005"]' # Optional, URLs for development plugins

# ===== External Service Configuration =====
REEARTH_WEB_PLATFORM_URL=<your-platform-url>


