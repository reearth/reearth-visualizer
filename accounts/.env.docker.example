
# Example Docker environment configuration for reearth-accounts-api

# Server Configuration
SKIP_DOTENV=true
REEARTH_HOST=0.0.0.0
REEARTH_PORT=8090

# Database Configuration
REEARTH_ACCOUNTS_DB=mongodb://<mongo-host>:27017/?directConnection=true
REEARTH_ACCOUNTS_DB_NAME=<db-name>

# Cerbos Configuration
CERBOS_HOST=<cerbos-host>:3593
REEARTH_ACCOUNTS_CERBOS_USE_SSL=false

# CORS Configuration
REEARTH_ACCOUNTS_ORIGINS=http://localhost:3000,http://<dev-host>,https://*.netlify.app

# Mock auth for development
REEARTH_MOCK_AUTH=false

# Auth0 Configuration
# These settings are shared with reearth-visualizer via authConfig GraphQL Query
# Get these values from your Auth0 application settings
REEARTH_AUTH0_DOMAIN=https://<your-auth0-domain>
REEARTH_AUTH0_AUDIENCE=https://<your-auth0-audience>
REEARTH_AUTH0_CLIENTID=<your-auth0-clientid>
REEARTH_AUTH0_CLIENTSECRET=<your-auth0-clientsecret>
