# ========================================
# Re:Earth Visualizer Environment Configuration
# ========================================

# ----------------------------------------
# General
# ----------------------------------------
PORT=8080

# ----------------------------------------
# Accounts API
# ----------------------------------------
REEARTH_ACCOUNTSAPI_HOST=http://localhost:8090

# ----------------------------------------
# Auth (Auth0)
# ----------------------------------------
REEARTH_AUTH0_AUDIENCE=https://api.reearth.example.com
REEARTH_AUTH0_CLIENTID=
REEARTH_AUTH0_CLIENTSECRET=
REEARTH_AUTH0_DOMAIN=https://example.auth0.com
REEARTH_AUTH0_WEBCLIENTID=

# ----------------------------------------
# Auth (Multiple providers)
# ----------------------------------------
#REEARTH_AUTH=[{"ISS":"https://hoge.com","AUD":["https://api.reearth.example.com"]}]
#REEARTH_AUTH_AUD=https://api.reearth.example.com
#REEARTH_AUTH_ISS=https://hoge.com

# ----------------------------------------
# Auth (AWS Cognito)
# ----------------------------------------
REEARTH_COGNITO_CLIENTID=
REEARTH_COGNITO_REGION=
REEARTH_COGNITO_USERPOOLID=

# ----------------------------------------
# Database
# ----------------------------------------
REEARTH_DB=mongodb://localhost
REEARTH_DB_ACCOUNT=reearth-account
REEARTH_DB_VIS=reearth

# ----------------------------------------
# Domain Checker
# ----------------------------------------
#REEARTH_VISUALIZER_DOMAINCHECKER_ENDPOINT=http://localhost/api/internal/domain
#REEARTH_VISUALIZER_DOMAINCHECKER_TOKEN=token
#REEARTH_VISUALIZER_DOMAINCHECKER_TYPE=http

# ----------------------------------------
# Extension Plugin
# ----------------------------------------
#REEARTH_EXT_PLUGIN=http://fileserve.local:8090/pluging-01,http://fileserve.local:8090/pluging-02

# ----------------------------------------
# General Settings
# ----------------------------------------
REEARTH_ASSETBASEURL=http://localhost:8080/assets
REEARTH_DEV=false
REEARTH_HOST=http://localhost:8080
REEARTH_HOST_WEB=http://localhost:3000

# ----------------------------------------
# Health Check
# ----------------------------------------
REEARTH_HEALTHCHECK_PASSWORD=
REEARTH_HEALTHCHECK_USERNAME=

# ----------------------------------------
# Internal API
# ----------------------------------------
REEARTH_VISUALIZER_INTERNALAPI_ACTIVE=false
REEARTH_VISUALIZER_INTERNALAPI_PORT=50052
REEARTH_VISUALIZER_INTERNALAPI_TOKEN=token

# ----------------------------------------
# Mailer
# Available: log, smtp, sendgrid, ses
# ----------------------------------------
REEARTH_MAILER=log

# ----------------------------------------
# Mailer (SendGrid)
# ----------------------------------------
#REEARTH_SENDGRID_API=
#REEARTH_SENDGRID_EMAIL=noreplay@test.com
#REEARTH_SENDGRID_NAME=

# ----------------------------------------
# Mailer (AWS SES)
# ----------------------------------------
REEARTH_SES_EMAIL=noreplay@test.com
REEARTH_SES_NAME=

# ----------------------------------------
# Mailer (SMTP)
# ----------------------------------------
#REEARTH_SMTP_EMAIL=noreplay@test.com
#REEARTH_SMTP_HOST=smtp.sendgrid.net
#REEARTH_SMTP_PASSWORD=Your_SendGrid_Token
#REEARTH_SMTP_PORT=587
#REEARTH_SMTP_SMTPUSERNAME=apikey

# ----------------------------------------
# Policy Checker
# Type: "http" or "permissive" (default)
# ----------------------------------------
REEARTH_VISUALIZER_POLICY_CHECKER_ENDPOINT=https://cloud.visualizer.dev.reearth.io/api/internal/policy-check
REEARTH_VISUALIZER_POLICY_CHECKER_TIMEOUT=30
REEARTH_VISUALIZER_POLICY_CHECKER_TOKEN=''
REEARTH_VISUALIZER_POLICY_CHECKER_TYPE=permissive

# ----------------------------------------
# Storage (GCP/GCS)
# ----------------------------------------
GOOGLE_CLOUD_PROJECT=
REEARTH_GCS_BUCKETNAME=test-bucket
REEARTH_GCS_ISFAKE=true
REEARTH_GCS_PUBLICATIONCACHECONTROL=no-store
STORAGE_EMULATOR_HOST=http://reearth-gcs:4443

# ----------------------------------------
# Storage (AWS S3)
# ----------------------------------------
#REEARTH_S3_BUCKETNAME=bucket_name
#REEARTH_S3_PUBLICATIONCACHECONTROL=
