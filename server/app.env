# Re:Earth Visualizer Backend Environment Variables
#
# Values are stored in 1Password (vault: "Visualizer", item: "Visualizer BE secrets OSS").
# Run with `op inject -i app.env -o .env.docker` to resolve secrets into .env.docker,
# or wrap the Go process directly: `op run --env-file=app.env -- go run ./cmd/reearth`.

# Database
REEARTH_DB="op://Visualizer/Visualizer BE secrets OSS/REEARTH_DB"
REEARTH_DB_ACCOUNT="op://Visualizer/Visualizer BE secrets OSS/REEARTH_DB_ACCOUNT"

# Server
REEARTH_SERVERHOST="op://Visualizer/Visualizer BE secrets OSS/REEARTH_SERVERHOST"

# GCS
STORAGE_EMULATOR_HOST="op://Visualizer/Visualizer BE secrets OSS/STORAGE_EMULATOR_HOST"
REEARTH_GCS_BUCKETNAME="op://Visualizer/Visualizer BE secrets OSS/REEARTH_GCS_BUCKETNAME"
REEARTH_GCS_ISFAKE="op://Visualizer/Visualizer BE secrets OSS/REEARTH_GCS_ISFAKE"
REEARTH_GCS_PUBLICATIONCACHECONTROL="op://Visualizer/Visualizer BE secrets OSS/REEARTH_GCS_PUBLICATIONCACHECONTROL"
GOOGLE_CLOUD_PROJECT="op://Visualizer/Visualizer BE secrets OSS/GOOGLE_CLOUD_PROJECT"

# Asset
REEARTH_ASSETBASEURL="op://Visualizer/Visualizer BE secrets OSS/REEARTH_ASSETBASEURL"

# Accounts API
REEARTH_ACCOUNTSAPI_HOST="op://Visualizer/Visualizer BE secrets OSS/REEARTH_ACCOUNTSAPI_HOST"

# Migration
RUN_MIGRATION="op://Visualizer/Visualizer BE secrets OSS/RUN_MIGRATION"

# Mock auth
REEARTH_MOCKAUTH="op://Visualizer/Visualizer BE secrets OSS/REEARTH_MOCKAUTH"

# Auth0 (web JWT validation only — M2M client not needed for local dev)
REEARTH_AUTH0_DOMAIN="op://Visualizer/Accounts BE secrets OSS/REEARTH_AUTH0_DOMAIN"
REEARTH_AUTH0_AUDIENCE="op://Visualizer/Accounts BE secrets OSS/REEARTH_AUTH0_AUDIENCE"
REEARTH_AUTH0_WEBCLIENTID="op://Visualizer/Accounts BE secrets OSS/REEARTH_AUTH0_WEBCLIENTID"

# Policy checker
REEARTH_VISUALIZER_POLICY_CHECKER_TYPE="op://Visualizer/Visualizer BE secrets OSS/REEARTH_VISUALIZER_POLICY_CHECKER_TYPE"
REEARTH_VISUALIZER_POLICY_CHECKER_ENDPOINT="op://Visualizer/Visualizer BE secrets OSS/REEARTH_VISUALIZER_POLICY_CHECKER_ENDPOINT"
REEARTH_CLOUD_INTERNAL_API_KEY="op://Visualizer/Visualizer BE secrets OSS/REEARTH_CLOUD_INTERNAL_API_KEY"
REEARTH_VISUALIZER_POLICY_CHECKER_TIMEOUT="op://Visualizer/Visualizer BE secrets OSS/REEARTH_VISUALIZER_POLICY_CHECKER_TIMEOUT"

# Dev
REEARTH_DEV="op://Visualizer/Visualizer BE secrets OSS/REEARTH_DEV"
REEARTH_VISUALIZER_INTERNALAPI_TOKEN="op://Visualizer/Visualizer BE secrets OSS/REEARTH_VISUALIZER_INTERNALAPI_TOKEN"
