# Re:Earth Visualizer Backend Environment Variables
#
# Values are stored in 1Password (vault: "Visualizer", item: "Backend ENV OSS").
# Run with `op inject -i app.env -o .env.docker` to resolve secrets into .env.docker,
# or wrap the Go process directly: `op run --env-file=app.env -- go run ./cmd/reearth`.

# Database
REEARTH_DB="op://Visualizer/Backend ENV OSS/REEARTH_DB"
REEARTH_DB_ACCOUNT="op://Visualizer/Backend ENV OSS/REEARTH_DB_ACCOUNT"

# Server
REEARTH_SERVERHOST="op://Visualizer/Backend ENV OSS/REEARTH_SERVERHOST"

# GCS
STORAGE_EMULATOR_HOST="op://Visualizer/Backend ENV OSS/STORAGE_EMULATOR_HOST"
REEARTH_GCS_BUCKETNAME="op://Visualizer/Backend ENV OSS/REEARTH_GCS_BUCKETNAME"
REEARTH_GCS_ISFAKE="op://Visualizer/Backend ENV OSS/REEARTH_GCS_ISFAKE"
GOOGLE_CLOUD_PROJECT="op://Visualizer/Backend ENV OSS/GOOGLE_CLOUD_PROJECT"

# Asset
REEARTH_ASSETBASEURL="op://Visualizer/Backend ENV OSS/REEARTH_ASSETBASEURL"

# Accounts API
REEARTH_ACCOUNTSAPI_ENABLED="op://Visualizer/Backend ENV OSS/REEARTH_ACCOUNTSAPI_ENABLED"
REEARTH_ACCOUNTSAPI_HOST="op://Visualizer/Backend ENV OSS/REEARTH_ACCOUNTSAPI_HOST"

# Migration
RUN_MIGRATION="op://Visualizer/Backend ENV OSS/RUN_MIGRATION"

# Mock auth
REEARTH_MOCKAUTH="op://Visualizer/Backend ENV OSS/REEARTH_MOCKAUTH"

# Dashboard API
REEARTH_DASHBOARD_API="op://Visualizer/Backend ENV OSS/REEARTH_DASHBOARD_API"

# Policy checker
REEARTH_VISUALIZER_POLICY_CHECKER_TYPE="op://Visualizer/Backend ENV OSS/REEARTH_VISUALIZER_POLICY_CHECKER_TYPE"
REEARTH_VISUALIZER_POLICY_CHECKER_ENDPOINT="op://Visualizer/Backend ENV OSS/REEARTH_VISUALIZER_POLICY_CHECKER_ENDPOINT"
# REEARTH_CLOUD_INTERNAL_API_KEY — add to 1Password item "Backend ENV OSS" before injecting
REEARTH_VISUALIZER_POLICY_CHECKER_TIMEOUT="op://Visualizer/Backend ENV OSS/REEARTH_VISUALIZER_POLICY_CHECKER_TIMEOUT"

# Dev
REEARTH_DEV="op://Visualizer/Backend ENV OSS/REEARTH_DEV"
REEARTH_VISUALIZER_INTERNALAPI_TOKEN="op://Visualizer/Backend ENV OSS/REEARTH_VISUALIZER_INTERNALAPI_TOKEN"
