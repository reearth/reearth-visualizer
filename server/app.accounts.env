# Re:Earth Accounts Environment Variables
#
# Values are stored in 1Password (vault: "Visualizer", item: "Backend ENV OSS").
# Run with `op inject -i app.accounts.env -o .env.accounts.docker` to resolve secrets.

# Server
SKIP_DOTENV="op://Visualizer/Backend ENV OSS/SKIP_DOTENV"
REEARTH_HOST="op://Visualizer/Backend ENV OSS/REEARTH_HOST"
REEARTH_PORT="op://Visualizer/Backend ENV OSS/REEARTH_PORT"

# Database
REEARTH_ACCOUNTS_DB="op://Visualizer/Backend ENV OSS/REEARTH_ACCOUNTS_DB"
REEARTH_ACCOUNTS_DB_NAME="op://Visualizer/Backend ENV OSS/REEARTH_ACCOUNTS_DB_NAME"

# Cerbos
CERBOS_HOST="op://Visualizer/Backend ENV OSS/CERBOS_HOST"

# CORS
REEARTH_ACCOUNTS_ORIGINS="op://Visualizer/Backend ENV OSS/REEARTH_ACCOUNTS_ORIGINS"

# Mock auth
REEARTH_MOCK_AUTH="op://Visualizer/Backend ENV OSS/REEARTH_MOCK_AUTH"

# Auth0
REEARTH_AUTH0_DOMAIN="op://Visualizer/Backend ENV OSS/REEARTH_AUTH0_DOMAIN"
REEARTH_AUTH0_AUDIENCE="op://Visualizer/Backend ENV OSS/REEARTH_AUTH0_AUDIENCE"
REEARTH_AUTH0_CLIENTID="op://Visualizer/Backend ENV OSS/REEARTH_AUTH0_CLIENTID"
REEARTH_AUTH0_CLIENTSECRET="op://Visualizer/Backend ENV OSS/REEARTH_AUTH0_CLIENTSECRET"
REEARTH_AUTH0_WEBCLIENTID="op://Visualizer/Backend ENV OSS/REEARTH_AUTH0_WEBCLIENTID"
